<Window x:Class="Lighting.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Lighting"
        mc:Ignorable="d"
        Title="Освещение — Вход"
        Icon="res/app_icon.ico"
        Height="450" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#2C3E50">
        <Border Width="380" Height="400"
                Background="White"
                CornerRadius="10"
                VerticalAlignment="Center"
                HorizontalAlignment="Center">
            <Grid Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <TextBlock Text="ВОЛЬТМАРКЕТ"
                               FontSize="22" FontWeight="Bold"
                               Foreground="#2C3E50" TextAlignment="Center"/>
                    <TextBlock Text="Освещение"
                               FontSize="14" Foreground="#7F8C8D" TextAlignment="Center"/>
                </StackPanel>

                <TextBlock Grid.Row="1" Text="Логин:"
                           FontSize="14" Foreground="#34495E" Margin="0,0,0,3"/>
                <TextBox x:Name="txtLogin" Grid.Row="2" FontSize="14" Height="35" Margin="0,0,0,10" Padding="5"/>

                <TextBlock Grid.Row="3" Text="Пароль:"
                           FontSize="14" Foreground="#34495E" Margin="0,0,0,3"/>
                <PasswordBox x:Name="txtPassword" Grid.Row="4" FontSize="14" Height="35" Margin="0,0,0,10" Padding="5"/>

                <Button x:Name="btnLogin" Grid.Row="5"
                        Content="ВОЙТИ" FontSize="16" FontWeight="Bold" Height="40"
                        Background="#3498DB" Foreground="White"
                        Click="BtnLogin_Click" Margin="0,0,0,5"/>

                <Button x:Name="btnRegister" Grid.Row="6"
                        Content="РЕГИСТРАЦИЯ" FontSize="14" Height="35"
                        Background="#95A5A6" Foreground="White"
                        Click="BtnRegister_Click" Margin="0,0,0,5"/>

                <TextBlock x:Name="txtError" Grid.Row="7" Text=""
                           Foreground="Red" TextAlignment="Center" Margin="0,5,0,0" FontSize="12"/>
            </Grid>
        </Border>
    </Grid>
</Window>
