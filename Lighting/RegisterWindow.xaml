<Window x:Class="Lighting.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Освещение — Регистрация" Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Background="#2C3E50">
        <Border Width="380" Height="450" Background="White" CornerRadius="10"
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="РЕГИСТРАЦИЯ" FontSize="20" FontWeight="Bold"
                           Foreground="#2C3E50" TextAlignment="Center" Margin="0,0,0,10"/>

                <TextBlock Grid.Row="1" Text="Логин:*" FontSize="13" Foreground="#34495E"/>
                <TextBox x:Name="txtRegLogin" Grid.Row="2" Height="30" Margin="0,0,0,5" Padding="3"/>

                <TextBlock Grid.Row="3" Text="Пароль:*" FontSize="13" Foreground="#34495E"/>
                <PasswordBox x:Name="txtRegPassword" Grid.Row="4" Height="30" Margin="0,0,0,5" Padding="3"/>

                <TextBlock Grid.Row="5" Text="Подтверждение пароля:*" FontSize="13" Foreground="#34495E"/>
                <PasswordBox x:Name="txtRegPasswordConfirm" Grid.Row="6" Height="30" Margin="0,0,0,5" Padding="3"/>

                <TextBlock Grid.Row="7" Text="Email:*" FontSize="13" Foreground="#34495E"/>
                <TextBox x:Name="txtRegEmail" Grid.Row="8" Height="30" Margin="0,0,0,5" Padding="3"/>

                <TextBlock Grid.Row="9" Text="ФИО:*" FontSize="13" Foreground="#34495E"/>
                <TextBox x:Name="txtRegFullName" Grid.Row="10" Height="30" Margin="0,0,0,10" Padding="3"/>

                <Button x:Name="btnRegisterSubmit" Grid.Row="11"
                        Content="ЗАРЕГИСТРИРОВАТЬСЯ" FontSize="14" FontWeight="Bold" Height="35"
                        Background="#27AE60" Foreground="White"
                        Click="BtnRegisterSubmit_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
