<Window x:Class="Lighting.ProductViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Просмотр товара"
        Height="520" Width="650"
        WindowStartupLocation="CenterScreen"
        FontSize="13">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Артикул:" FontWeight="Bold" Margin="0,0,10,4"/>
            <TextBlock Grid.Row="0" Grid.Column="1" x:Name="txtArticle" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Наименование:" FontWeight="Bold" Margin="0,0,10,4"/>
            <TextBlock Grid.Row="1" Grid.Column="1" x:Name="txtName" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Категория:" FontWeight="Bold" Margin="0,0,10,4"/>
            <TextBlock Grid.Row="2" Grid.Column="1" x:Name="txtCategory" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Производитель:" FontWeight="Bold" Margin="0,0,10,4"/>
            <TextBlock Grid.Row="3" Grid.Column="1" x:Name="txtManufacturer" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Цена:" FontWeight="Bold" Margin="0,0,10,4"/>
            <TextBlock Grid.Row="4" Grid.Column="1" x:Name="txtPrice" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Остаток:" FontWeight="Bold" Margin="0,0,10,4"/>
            <TextBlock Grid.Row="5" Grid.Column="1" x:Name="txtStock" Margin="0,0,0,4"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Описание:" FontWeight="Bold" Margin="0,0,10,4" VerticalAlignment="Top"/>
            <TextBlock Grid.Row="6" Grid.Column="1" x:Name="txtDescription" TextWrapping="Wrap" Margin="0,0,0,4"/>
        </Grid>

        <GroupBox Grid.Row="1" Header="Характеристики" Margin="0,0,0,8">
            <DataGrid x:Name="dgViewCharacteristics"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Height="150"
                      FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Характеристика" Binding="{Binding CharName}" Width="200"/>
                    <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="250"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <Button Grid.Row="2" Content="Закрыть" Width="120" Height="30"
                Background="#95A5A6" Foreground="White" FontSize="13"
                HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Click="BtnClose_Click"/>
    </Grid>
</Window>
