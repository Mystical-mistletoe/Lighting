<Window x:Class="Lighting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Lighting"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Освещение"
        Icon="res/app_icon.ico"
        Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Grid Margin="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="ВОЛЬТМАРКЕТ — ВСЕ ДЛЯ ОСВЕЩЕНИЯ"
                   FontSize="18" FontWeight="Bold"
                   Background="#2C3E50" Foreground="White"
                   Padding="8" TextAlignment="Center"/>

        <TabControl Grid.Row="1" x:Name="MainTabControl">

            <!-- ========== ТОВАРЫ ========== -->
            <TabItem Header="Товары" x:Name="tabProducts">
                <Grid Margin="5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="Auto" MinHeight="30"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель поиска -->
                    <Border Grid.Row="0" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="5" Margin="0,0,0,3" Background="#ECF0F1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="Условия поиска:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="13"/>
                                <Button x:Name="btnAddCondition" Content="+ Добавить условие" Background="#3498DB" Foreground="White" FontSize="12" Height="26" Click="BtnAddCondition_Click" Margin="0,0,5,0"/>
                                <Button x:Name="btnSearch" Content="Поиск" Background="#27AE60" Foreground="White" FontSize="12" Height="26" Click="BtnSearch_Click" Margin="0,0,5,0"/>
                                <Button x:Name="btnClearSearch" Content="Сбросить" Background="#95A5A6" Foreground="White" FontSize="12" Height="26" Click="BtnClearSearch_Click"/>
                            </StackPanel>
                            <ItemsControl Grid.Row="1" x:Name="icSearchConditions" Margin="0,0,0,2"/>
                        </Grid>
                    </Border>

                    <!-- Настройка столбцов -->
                    <Border Grid.Row="1" BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="5" Padding="4" Margin="0,0,0,3" Background="#F9F9F9">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Столбцы:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                            <CheckBox x:Name="chkColArticle" Content="Артикул" IsChecked="True" Margin="0,0,8,0" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                            <CheckBox x:Name="chkColName" Content="Наименование" IsChecked="True" Margin="0,0,8,0" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                            <CheckBox x:Name="chkColCategory" Content="Категория" IsChecked="True" Margin="0,0,8,0" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                            <CheckBox x:Name="chkColManufacturer" Content="Производитель" IsChecked="True" Margin="0,0,8,0" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                            <CheckBox x:Name="chkColPrice" Content="Цена" IsChecked="True" Margin="0,0,8,0" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                            <CheckBox x:Name="chkColStock" Content="Остаток" IsChecked="True" Margin="0,0,8,0" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                            <CheckBox x:Name="chkColDescription" Content="Описание" IsChecked="False" Margin="0,0,8,0" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                            <CheckBox x:Name="chkColCreatedAt" Content="Дата" IsChecked="False" FontSize="12" Checked="OnColumnVisibilityChanged" Unchecked="OnColumnVisibilityChanged"/>
                        </StackPanel>
                    </Border>

                        <!-- Таблица товаров -->
                    <ScrollViewer Grid.Row="3" 
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Auto"
                        CanContentScroll="True">
                        <DataGrid Grid.Row="3" x:Name="dgProducts"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="False"
                                  SelectionMode="Extended"
                                  Margin="0,0,0,3"
                              CanUserSortColumns="True"
                              SelectionChanged="DgProducts_SelectionChanged"
                              MouseDoubleClick="DgProducts_MouseDoubleClick"
                              FontSize="12">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Выбор" Binding="{Binding IsSelected}" Width="45"/>
                                <DataGridTextColumn x:Name="colArticle" Header="Артикул" Binding="{Binding Article}" Width="90" IsReadOnly="True"/>
                                <DataGridTextColumn x:Name="colName" Header="Наименование" Binding="{Binding Name}" Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn x:Name="colCategory" Header="Категория" Binding="{Binding CategoryName}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn x:Name="colManufacturer" Header="Производитель" Binding="{Binding ManufacturerName}" Width="120" IsReadOnly="True"/>
                                <DataGridTextColumn x:Name="colPrice" Header="Цена" Binding="{Binding Price, StringFormat={}{0:F2} ₽}" Width="90" IsReadOnly="True"/>
                                <DataGridTextColumn x:Name="colStock" Header="Остаток" Binding="{Binding StockQuantity}" Width="60" IsReadOnly="True"/>
                                <DataGridTextColumn x:Name="colDescription" Header="Описание" Binding="{Binding Description}" Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn x:Name="colCreatedAt" Header="Дата" Binding="{Binding CreatedAt, StringFormat={}{0:dd.MM.yyyy}}" Width="100" IsReadOnly="True"/>
                                </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                    
                    <!-- Кнопки действий -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,2,0,2">
                        <Button x:Name="btnCompare" Content="Сравнить" Background="#8E44AD" Foreground="White" Width="100" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnCompare_Click"/>
                        <Button x:Name="btnToggleSelect" Content="Выделить все" Background="#34495E" Foreground="White" Width="100" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnToggleSelect_Click"/>
                        <Button x:Name="btnAddProduct" Content="Добавить" Background="#27AE60" Foreground="White" Width="90" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnAddProduct_Click"/>
                        <Button x:Name="btnViewProduct" Content="Просмотр" Background="#2C3E50" Foreground="White" Width="80" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnViewProduct_Click"/>
                        <Button x:Name="btnEditProduct" Content="Редактировать" Background="#F39C12" Foreground="White" Width="100" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnEditProduct_Click"/>
                        <Button x:Name="btnDeleteProduct" Content="Удалить" Background="#E74C3C" Foreground="White" Width="80" Height="26" FontSize="12" Click="BtnDeleteProduct_Click"/>
                        <Button x:Name="btnExportCsv" Content="Экспорт CSV" Background="#1ABC9C" Foreground="White" Width="100" Height="26" FontSize="12" Margin="4,0,0,0" Click="BtnExportCsv_Click"/>
                        <Button x:Name="btnImportCsv" Content="Импорт CSV" Background="#16A085" Foreground="White" Width="100" Height="26" FontSize="12" Margin="4,0,0,0" Click="BtnImportCsv_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== КАТЕГОРИИ ========== -->
            <TabItem Header="Категории">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Список категорий" FontWeight="Bold" FontSize="14"/>
                        <ListBox x:Name="lstCategories" Height="350" Margin="0,5"
                                 SelectionChanged="LstCategories_SelectionChanged"/>
                        <Button Content="Обновить" Height="24" FontSize="12" Margin="0,5" Click="BtnRefreshCategories_Click"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Редактирование категории" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Название:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtCategoryName" Width="250" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Описание:" Width="100" VerticalAlignment="Top" FontSize="13"/>
                            <TextBox x:Name="txtCategoryDescription" Width="250" Height="70" TextWrapping="Wrap" AcceptsReturn="True" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8" HorizontalAlignment="Center">
                            <Button x:Name="btnAddCategory" Content="Добавить" Background="#27AE60" Foreground="White" Width="90" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnAddCategory_Click"/>
                            <Button x:Name="btnUpdateCategory" Content="Обновить" Background="#F39C12" Foreground="White" Width="90" Height="26" FontSize="12" Margin="4,0" Click="BtnUpdateCategory_Click"/>
                            <Button x:Name="btnDeleteCategory" Content="Удалить" Background="#E74C3C" Foreground="White" Width="80" Height="26" FontSize="12" Margin="4,0,0,0" Click="BtnDeleteCategory_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== ПРОИЗВОДИТЕЛИ ========== -->
            <TabItem Header="Производители">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Список производителей" FontWeight="Bold" FontSize="14"/>
                        <ListBox x:Name="lstManufacturers" Height="350" Margin="0,5"
                                 SelectionChanged="LstManufacturers_SelectionChanged"/>
                        <Button Content="Обновить" Height="24" FontSize="12" Margin="0,5" Click="BtnRefreshManufacturers_Click"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Редактирование производителя" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Название:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtManufacturerName" Width="250" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Страна:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtManufacturerCountry" Width="250" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Сайт:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtManufacturerWebsite" Width="250" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8" HorizontalAlignment="Center">
                            <Button x:Name="btnAddManufacturer" Content="Добавить" Background="#27AE60" Foreground="White" Width="90" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnAddManufacturer_Click"/>
                            <Button x:Name="btnUpdateManufacturer" Content="Обновить" Background="#F39C12" Foreground="White" Width="90" Height="26" FontSize="12" Margin="4,0" Click="BtnUpdateManufacturer_Click"/>
                            <Button x:Name="btnDeleteManufacturer" Content="Удалить" Background="#E74C3C" Foreground="White" Width="80" Height="26" FontSize="12" Margin="4,0,0,0" Click="BtnDeleteManufacturer_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== ХАРАКТЕРИСТИКИ ========== -->
            <TabItem Header="Характеристики">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Список характеристик -->
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Список характеристик" FontWeight="Bold" FontSize="14"/>
                        <ListBox x:Name="lstCharacteristics" Height="200" Margin="0,5"
                                 SelectionChanged="LstCharacteristics_SelectionChanged"/>
                        <Button Content="Обновить" Height="24" FontSize="12" Margin="0,5" Click="BtnRefreshCharacteristics_Click"/>
                    </StackPanel>

                    <!-- Редактирование характеристики + значения -->
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Редактирование характеристики" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="Название:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtCharacteristicName" Width="220" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Ед. измерения:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtCharacteristicUnit" Width="220" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5" HorizontalAlignment="Center">
                            <Button x:Name="btnAddCharacteristic" Content="Добавить" Background="#27AE60" Foreground="White" Width="90" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnAddCharacteristic_Click"/>
                            <Button x:Name="btnUpdateCharacteristic" Content="Обновить" Background="#F39C12" Foreground="White" Width="90" Height="26" FontSize="12" Margin="4,0" Click="BtnUpdateCharacteristic_Click"/>
                            <Button x:Name="btnDeleteCharacteristic" Content="Удалить" Background="#E74C3C" Foreground="White" Width="80" Height="26" FontSize="12" Margin="4,0,0,0" Click="BtnDeleteCharacteristic_Click"/>
                        </StackPanel>

                        <!-- Стандартные значения характеристики -->
                        <Border BorderBrush="#BDC3C7" BorderThickness="1" CornerRadius="4" Padding="5" Margin="0,8,0,0" Background="#F9F9F9">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Стандартные значения" FontWeight="Bold" FontSize="13" Margin="0,0,0,4"/>
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBox x:Name="txtNewCharValue" Width="140" FontSize="12" Margin="0,0,4,0"/>
                                    <Button x:Name="btnAddCharValue" Content="+" Width="30" Height="24" FontSize="14" FontWeight="Bold"
                                            Background="#3498DB" Foreground="White" Click="BtnAddCharValue_Click" Margin="0,0,4,0"/>
                                    <Button x:Name="btnDeleteCharValue" Content="✕" Width="30" Height="24" FontSize="12"
                                            Background="#E74C3C" Foreground="White" Click="BtnDeleteCharValue_Click"/>
                                </StackPanel>
                                <DataGrid x:Name="dgCharacteristicValues"
                                          Grid.Row="2"
                                          AutoGenerateColumns="False"
                                          IsReadOnly="False"
                                          Height="120"
                                          FontSize="12"
                                          CellEditEnding="DgCharacteristicValues_CellEditEnding"
                                          KeyDown="DgCharacteristicValues_KeyDown">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="150"/>
                                        <DataGridTextColumn Header="Товаров" Binding="{Binding ProductCount}" Width="70" IsReadOnly="True"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== ПОЛЬЗОВАТЕЛИ ========== -->
            <TabItem Header="Пользователи" x:Name="tabUsers">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="5">
                        <TextBlock Text="Список пользователей" FontWeight="Bold" FontSize="14"/>
                        <DataGrid x:Name="dgUsers" AutoGenerateColumns="False" IsReadOnly="True" Height="350" Margin="0,5" FontSize="12"
                                  SelectionChanged="DgUsers_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="35"/>
                                <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="100"/>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="140"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="140"/>
                                <DataGridTextColumn Header="Роль" Binding="{Binding Role}" Width="70"/>
                                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                        <Button Content="Обновить" Height="24" FontSize="12" Margin="0,5" Click="BtnRefreshUsers_Click"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5">
                        <TextBlock Text="Редактирование пользователя" FontWeight="Bold" FontSize="14"/>
                        <StackPanel Orientation="Horizontal" Margin="0,8">
                            <TextBlock Text="ID:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtUserId" Width="250" IsReadOnly="True" Background="LightGray" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Логин:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtUserLogin" Width="250" IsReadOnly="True" Background="LightGray" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="ФИО:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtUserFullName" Width="250" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Email:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <TextBox x:Name="txtUserEmail" Width="250" FontSize="13"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Роль:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <ComboBox x:Name="cmbUserRole" Width="250" FontSize="13">
                                <ComboBoxItem Content="user"/>
                                <ComboBoxItem Content="manager"/>
                                <ComboBoxItem Content="admin"/>
                            </ComboBox>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Заблокирован:" Width="100" VerticalAlignment="Center" FontSize="13"/>
                            <CheckBox x:Name="chkUserBlocked" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8" HorizontalAlignment="Center">
                            <Button x:Name="btnUpdateUser" Content="Обновить" Background="#F39C12" Foreground="White" Width="100" Height="26" FontSize="12" Margin="0,0,4,0" Click="BtnUpdateUser_Click"/>
                            <Button x:Name="btnDeleteUser" Content="Удалить" Background="#E74C3C" Foreground="White" Width="80" Height="26" FontSize="12" Click="BtnDeleteUser_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ========== СТАТИСТИКА ========== -->
            <TabItem Header="Статистика">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Товаров по категориям" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                    <DataGrid Grid.Row="1" x:Name="dgStatsByCategory"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Height="200" Margin="0,0,0,10" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Категория" Binding="{Binding CategoryName}" Width="250"/>
                            <DataGridTextColumn Header="Кол-во товаров" Binding="{Binding ProductCount}" Width="120"/>
                            <DataGridTextColumn Header="Средняя цена" Binding="{Binding AvgPrice, StringFormat={}{0:F2} ₽}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock Grid.Row="2" Text="Товаров по производителям" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                    <DataGrid Grid.Row="3" x:Name="dgStatsByManufacturer"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              Height="200" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Производитель" Binding="{Binding ManufacturerName}" Width="200"/>
                            <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="100"/>
                            <DataGridTextColumn Header="Кол-во товаров" Binding="{Binding ProductCount}" Width="120"/>
                            <DataGridTextColumn Header="Средняя цена" Binding="{Binding AvgPrice, StringFormat={}{0:F2} ₽}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Нижняя панель -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="txtUserInfo" Grid.Column="0"
                           Text="Пользователь: гость | Роль: user"
                           Foreground="White" VerticalAlignment="Center" FontSize="13"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="btnBackup" Content="Бэкап БД" Width="90" Height="26" FontSize="12"
                            Background="#8E44AD" Foreground="White" Margin="0,0,4,0" Click="BtnBackup_Click"/>
                    <Button x:Name="btnRestore" Content="Восстановить" Width="100" Height="26" FontSize="12"
                            Background="#E67E22" Foreground="White" Margin="0,0,4,0" Click="BtnRestore_Click"/>
                    <Button x:Name="btnLogout" Content="Выход" Width="80" Height="26"
                            FontSize="12" Background="#E74C3C" Foreground="White" Click="BtnLogout_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
