<Window x:Class="Lighting.CompareWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сравнение товаров"
        Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Режим отображения:" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <RadioButton x:Name="rbAll" Content="Все характеристики" GroupName="mode" IsChecked="True" Margin="0,0,10,0" Checked="OnModeChanged"/>
            <RadioButton x:Name="rbDifferences" Content="Только различия" GroupName="mode" Checked="OnModeChanged"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <DataGrid x:Name="dgCompare"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserSortColumns="False"
                      CanUserResizeColumns="True"
                       GridLinesVisibility="All"
                      RowHeaderWidth="0"
                      Margin="0,0,0,10">
            </DataGrid>
        </ScrollViewer>
    </Grid>
</Window>
