<Window x:Class="Lighting.ProductEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление/Редактирование товара"
        Height="600" Width="750"
        WindowStartupLocation="CenterScreen"
        FontSize="13">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Артикул:*" Margin="0,0,5,2"/>
            <TextBox x:Name="txtArticle" Grid.Row="0" Grid.Column="1" Margin="0,0,0,2" Height="26"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Наименование:*" Margin="0,0,5,2"/>
            <TextBox x:Name="txtName" Grid.Row="1" Grid.Column="1" Margin="0,0,0,2" Height="26"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Категория:*" Margin="0,0,5,2"/>
            <ComboBox x:Name="cmbCategory" Grid.Row="2" Grid.Column="1" Margin="0,0,0,2" Height="26"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Производитель:*" Margin="0,0,5,2"/>
            <ComboBox x:Name="cmbManufacturer" Grid.Row="3" Grid.Column="1" Margin="0,0,0,2" Height="26"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Цена:*" Margin="0,0,5,2"/>
            <TextBox x:Name="txtPrice" Grid.Row="4" Grid.Column="1" Margin="0,0,0,2" Height="26"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="Количество:*" Margin="0,0,5,2"/>
            <TextBox x:Name="txtStockQuantity" Grid.Row="5" Grid.Column="1" Margin="0,0,0,2" Height="26"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Изображение (URL):" Margin="0,0,5,2"/>
            <TextBox x:Name="txtImageUrl" Grid.Row="6" Grid.Column="1" Margin="0,0,0,2" Height="26"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="Описание:" Margin="0,0,5,2" VerticalAlignment="Top"/>
            <TextBox x:Name="txtDescription" Grid.Row="7" Grid.Column="1" Height="50" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,2" FontSize="12"/>
        </Grid>

        <!-- Характеристики товара -->
        <GroupBox Grid.Row="1" Header="Характеристики товара" Margin="0,3">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Добавить:" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="12"/>
                    <ComboBox x:Name="cmbNewCharacteristic" Width="180" Margin="0,0,4,0" Height="24" FontSize="12"
                              DisplayMemberPath="Name" SelectedValuePath="Id"
                              SelectionChanged="CmbNewCharacteristic_SelectionChanged"/>
                    <ComboBox x:Name="cmbNewCharValue" Width="160" Margin="0,0,4,0" Height="24" FontSize="12"
                              IsEditable="True"/>
                    <Button x:Name="btnAddChar" Content="Добавить" Background="#3498DB" Foreground="White" Height="24" FontSize="12" Click="BtnAddChar_Click"/>
                </StackPanel>

                <DataGrid Grid.Row="1" x:Name="dgCharacteristics"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          Margin="0,0,0,3"
                          FontSize="12">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Характеристика" Binding="{Binding CharName}" Width="180" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Значение" Binding="{Binding Value}" Width="200"/>
                        <DataGridTemplateColumn Header="Удалить" Width="50">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Background="#E74C3C" Foreground="White"
                                            Width="24" Height="22" FontSize="10"
                                            Click="BtnRemoveChar_Click"
                                            Tag="{Binding}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
            <Button x:Name="btnSave" Content="Сохранить" Background="#27AE60" Foreground="White"
                    Width="100" Height="30" FontSize="13" Margin="0,0,8,0" Click="BtnSave_Click"/>
            <Button Content="Отмена" Background="#95A5A6" Foreground="White"
                    Width="100" Height="30" FontSize="13" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
